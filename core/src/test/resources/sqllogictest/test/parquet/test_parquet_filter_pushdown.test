query I
SELECT COUNT(*) FROM parquet_scan('data/parquet-testing/date.parquet') WHERE d < '1975-01-01'::DATE OR d > '1976-01-01'::DATE
----
21

query I
SELECT COUNT(*) FROM parquet_scan('data/parquet-testing/date.parquet') WHERE d < '1975-01-01'::DATE OR d >= '1976-01-01'::DATE
----
