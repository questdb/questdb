# Basic correlated inner lateral join
query ITR nosort
SELECT o.id, o.customer, t.qty
FROM orders o
JOIN LATERAL (SELECT qty FROM trades WHERE order_id = o.id) t
ORDER BY o.id, t.qty
----
1 Alice 10.000000
1 Alice 20.000000
1 Alice 30.000000
2 Bob 30.000000
3 Charlie 40.000000
3 Charlie 50.000000

# CROSS JOIN LATERAL — same behavior as implicit lateral
query IR nosort
SELECT o.id, t.qty
FROM orders o
CROSS JOIN LATERAL (SELECT qty FROM trades WHERE order_id = o.id) t
ORDER BY o.id, t.qty
