# WHERE with OR referencing outer column
query II nosort
SELECT t1_or.a, x.result
FROM t1_or
CROSS JOIN LATERAL (
    SELECT val + t1_or.b AS result
    FROM (
        SELECT val FROM t2_or WHERE t2_or.t1_id = t1_or.a
    )
    WHERE val > t1_or.threshold OR val < 5
) x
ORDER BY t1_or.a, x.result
----
