# Nested lateral: outer -> lateral (middle -> lateral (inner))
query IIIIIT nosort
SELECT n_t1.id, sub1.id1, sub1.t1_id, sub1.id2, sub1.t2_id, sub1.ts2
FROM n_t1
JOIN LATERAL (
    SELECT n_t2.id AS id1, n_t2.t1_id, sub2.id AS id2, sub2.t2_id, sub2.ts AS ts2
    FROM n_t2
    JOIN LATERAL (SELECT * FROM n_t3 WHERE n_t3.t2_id = n_t2.id) sub2 ON 1 = 1
    WHERE n_t2.t1_id = n_t1.id
) sub1
----
1 1 1 1 1 2024-01-01 01:00:00

