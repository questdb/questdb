query IIT nosort
SELECT o.id, sub.val, sub.info
FROM t_outer_lj o
JOIN LATERAL (
    SELECT l.val, r.info
    FROM t_left_lj l
    LEFT JOIN t_right_lj r ON l.id = r.ref_id AND r.id = o.id
    WHERE l.id = o.id
) sub ON true
ORDER BY o.id
