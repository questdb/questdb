# UNION ALL with LIMIT in each branch
query II nosort
SELECT o.id, sub.val
FROM t_outer_ul o
JOIN LATERAL (
    (SELECT val FROM t_data_ul WHERE oid = o.id AND src = 'A' ORDER BY val LIMIT 1)
    UNION ALL
    (SELECT val FROM t_data_ul WHERE oid = o.id AND src = 'B' ORDER BY val LIMIT 1)
) sub ON true
ORDER BY o.id, sub.val
