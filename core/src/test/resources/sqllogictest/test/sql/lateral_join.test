# Both sides of the JOIN inside lateral are correlated
query III nosort
SELECT o.id, sub.val, sub.qty
FROM t_outer_cj o
JOIN LATERAL (
    SELECT a.val, b.qty
    FROM (SELECT val FROM t_a_cj WHERE t_a_cj.oid = o.id) a
    CROSS JOIN (SELECT qty FROM t_b_cj WHERE t_b_cj.oid = o.id) b
) sub ON true
ORDER BY o.id, sub.val
