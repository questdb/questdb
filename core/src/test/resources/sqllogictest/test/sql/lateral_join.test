# Lateral with left join producing NULLs
query IIT nosort
SELECT ss.unique2, x.f1, x.ts
FROM int4_tbl x LEFT JOIN LATERAL (
    SELECT 9998 AS unique2
    FROM int4_tbl i2
    WHERE i2.f1 = x.f1 AND i2.f1 = 0
    LIMIT 1
) ss ON true
ORDER BY x.f1
