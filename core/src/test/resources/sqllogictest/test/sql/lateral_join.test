# Lateral join with explicit LATERAL — SUM aggregate correlated
query IR nosort
SELECT name, total FROM students JOIN LATERAL (SELECT SUM(grade) AS total FROM exams WHERE exams.sid = students.id) grades ORDER BY total DESC
