# PIVOT inside lateral — buy/sell totals per order
query IRR nosort
SELECT o.id, t.buy, t.sell
FROM orders_pv o
JOIN LATERAL (
    SELECT * FROM (
        SELECT side, SUM(qty) AS total
        FROM trades_pv
        WHERE order_id = o.id
        GROUP BY side
    ) PIVOT (SUM(total) FOR side IN ('buy', 'sell'))
) t
ORDER BY o.id
----
