# UNION with nested subquery inside branch
query II nosort
SELECT t1_deep.x, sub.val FROM t1_deep
CROSS JOIN LATERAL (
    SELECT SUM(a) AS val FROM t2_deep WHERE t2_deep.x = t1_deep.x
    UNION ALL
    SELECT s FROM (
        SELECT SUM(b) AS s FROM t3_deep WHERE t3_deep.x = t1_deep.x
    ) nested_sub
) sub
ORDER BY t1_deep.x, sub.val
