statement ok
CREATE TABLE n_t2 (id INT, t1_id INT, ts TIMESTAMP NOT NULL) TIMESTAMP(ts) 

statement ok
INSERT INTO n_t2 VALUES (1, 1, '2024-01-01T00:30:00.000000Z')

statement ok
CREATE TABLE n_t3 (id INT, t2_id INT, ts TIMESTAMP NOT NULL) TIMESTAMP(ts) 

statement ok
