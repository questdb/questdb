# Adapted from: lateral_join_chain.test
# ============================================================

statement ok
CREATE TABLE chain_t1 (id INT, val INT, ts TIMESTAMP NOT NULL) TIMESTAMP(ts) 

statement ok
INSERT INTO chain_t1 VALUES
(1, 10, '2024-01-01T00:00:00.000000Z'),
(2, 20, '2024-01-01T01:00:00.000000Z'),
(3, 30, '2024-01-01T02:00:00.000000Z')

statement ok
CREATE TABLE chain_t2 (t1_id INT, x INT, ts TIMESTAMP NOT NULL) TIMESTAMP(ts) 

statement ok
INSERT INTO chain_t2 VALUES
(1, 100, '2024-01-01T00:10:00.000000Z'),
(1, 200, '2024-01-01T00:20:00.000000Z'),
(2, 300, '2024-01-01T01:10:00.000000Z')

statement ok
CREATE TABLE chain_t3 (t2_x INT, label STRING, ts TIMESTAMP NOT NULL) TIMESTAMP(ts) 

statement ok
INSERT INTO chain_t3 VALUES
(100, 'alpha', '2024-01-01T00:10:00.000000Z'),
(200, 'beta', '2024-01-01T00:20:00.000000Z'),
(300, 'gamma', '2024-01-01T01:10:00.000000Z')

# Two chained lateral joins
query IIT nosort
SELECT c.id, s1.x, s2.label
FROM chain_t1 c
JOIN LATERAL (SELECT x FROM chain_t2 WHERE t1_id = c.id) s1
JOIN LATERAL (SELECT label FROM chain_t3 WHERE t2_x = s1.x) s2
ORDER BY c.id, s1.x
----
1 100 alpha
1 200 beta
2 300 gamma

