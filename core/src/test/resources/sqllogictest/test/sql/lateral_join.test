# UNION ALL with aggregate in second branch, filtered
query II nosort
SELECT t1_ua.x, sub.val FROM t1_ua
CROSS JOIN LATERAL (
    SELECT a AS val FROM t2_ua WHERE t2_ua.x = t1_ua.x
    UNION ALL
    SELECT total FROM (
        SELECT SUM(b) AS total FROM t3_ua WHERE t3_ua.x = t1_ua.x GROUP BY cat
    ) agg WHERE agg.total > 100
) sub
ORDER BY t1_ua.x, sub.val
