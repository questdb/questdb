# INTERSECT inside lateral — per-group intersection
# order 1: {10,20} intersect {10,30} = {10}
# order 2: {30} intersect {30} = {30}
query IR nosort
SELECT o.id, t.qty
FROM orders_isect o
JOIN LATERAL (
    SELECT qty FROM trades_ia WHERE order_id = o.id
    INTERSECT
    SELECT qty FROM trades_ib WHERE order_id = o.id
) t
ORDER BY o.id, t.qty
----
1 10.000000
2 30.000000

