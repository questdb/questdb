(2, 2, 19.99, '2024-01-01T01:20:00.000000Z')

# Inner JOIN inside lateral subquery
query ITR nosort
SELECT o.id, t.name, t.price
FROM orders_ij o
JOIN LATERAL (
    SELECT p.name, pr.price
    FROM products p
    JOIN prices pr ON pr.product_id = p.id
    WHERE p.order_id = o.id
) t
ORDER BY o.id
----
1 Widget 9.990000
2 Gadget 19.990000

